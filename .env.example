# AI Creative Lab — provider API keys
# Copy to .env in your project working directory and fill in the values
# you need. Skills validate keys before running and fail gracefully when
# a required key is missing.

# Video and image generation (Seedance 2.0, Nano Banana 2, gpt-image-2)
# Sign up: https://wavespeed.ai
WAVESPEED_API_KEY=

# Video QA, compliance, overlay/disclaimer burn
# Sign up: https://vidjutsu.ai
VIDJUTSU_API_KEY=

# Reference ad and creator content fetching
# Sign up: https://scrapecreators.com
SCRAPE_CREATORS_API_KEY=

# Publishing and scheduling
# Sign up: https://zernio.com
ZERNIO_API_KEY=

# Gemini — used for reference video analysis (clone-ad)
# Sign up: https://ai.google.dev
GEMINI_API_KEY=
