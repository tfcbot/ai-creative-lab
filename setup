#!/usr/bin/env bash
# AI Creative Agency — post-install setup
# Registers skills with Claude Code and/or Codex.

set -e

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$REPO_ROOT"

# ─── Flags ────────────────────────────────────────────────────
HOST="auto"
QUIET=0

while [ $# -gt 0 ]; do
  case "$1" in
    --host) [ -z "$2" ] && { echo "Missing value for --host (expected claude, codex, or auto)" >&2; exit 1; }; HOST="$2"; shift 2 ;;
    --host=*) HOST="${1#--host=}"; shift ;;
    -q|--quiet) QUIET=1; shift ;;
    -h|--help)
      cat <<EOF
AI Creative Agency setup

Usage: ./setup [--host <name>] [--quiet]

Hosts:
  claude     Register with Claude Code (~/.claude/skills/)
  codex      Register with Codex (~/.codex/skills/) — one symlink per skill
  auto       (default) Detect installed hosts and register with each
  openclaw   ACP-based — inherits Claude Code install (no separate setup)
  hermes     ACP-based — inherits Claude Code install (no separate setup)

Options:
  --quiet        Suppress non-error output
  --help         Show this help
EOF
      exit 0 ;;
    *) shift ;;
  esac
done

log() { [ "$QUIET" -eq 0 ] && echo "$@" || true; }

# ─── Validate host ────────────────────────────────────────────
case "$HOST" in
  claude|codex|auto) ;;
  openclaw|hermes)
    cat <<EOF

$HOST integration uses a different model — $HOST spawns Claude Code sessions
via ACP, so installing with --host claude (or auto) makes every skill
available in $HOST transparently. No separate $HOST setup is required.

EOF
    exit 0 ;;
  *) echo "Unknown --host: $HOST (expected claude, codex, auto, openclaw, or hermes)" >&2; exit 1 ;;
esac

# ─── Detect hosts ─────────────────────────────────────────────
INSTALL_CLAUDE=0
INSTALL_CODEX=0

if [ "$HOST" = "auto" ]; then
  [ -d "$HOME/.claude" ] && INSTALL_CLAUDE=1
  [ -d "$HOME/.codex" ] && INSTALL_CODEX=1
  if [ "$INSTALL_CLAUDE" -eq 0 ] && [ "$INSTALL_CODEX" -eq 0 ]; then
    echo "No supported host detected (looked for ~/.claude or ~/.codex)." >&2
    echo "Install Claude Code or Codex first, then re-run ./setup." >&2
    exit 1
  fi
elif [ "$HOST" = "claude" ]; then
  INSTALL_CLAUDE=1
elif [ "$HOST" = "codex" ]; then
  INSTALL_CODEX=1
fi

# ─── Discover skills ──────────────────────────────────────────
SKILLS=()
for dir in */; do
  dir="${dir%/}"
  case "$dir" in
    docs|lib|scripts|test|examples|node_modules|.git|.github|.claude|.agents) continue ;;
  esac
  [ -f "$dir/SKILL.md" ] && SKILLS+=("$dir")
done

if [ ${#SKILLS[@]} -eq 0 ]; then
  echo "⚠  No SKILL.md files found at the top level." >&2
  echo "   Expected layout: <skill-name>/SKILL.md" >&2
  exit 1
fi

# ─── Claude Code: one symlink per skill ───────────────────────
# Claude Code CLI traverses nested dirs, but Claude Code Desktop only
# discovers top-level entries under ~/.claude/skills/. Symlinking each
# bundled skill up one level supports both — Desktop sees the symlinks,
# CLI dedupes by frontmatter name: so the skill appears once either way.
# Skip-if-exists protects entries owned by other skill packs.
if [ "$INSTALL_CLAUDE" -eq 1 ]; then
  CLAUDE_SKILLS_DIR="$HOME/.claude/skills"
  case "$REPO_ROOT" in
    "$CLAUDE_SKILLS_DIR/"*)
      mkdir -p "$CLAUDE_SKILLS_DIR"
      linked=0
      skipped=()
      for skill in "${SKILLS[@]}"; do
        target="$CLAUDE_SKILLS_DIR/$skill"
        if [ -e "$target" ] && [ ! -L "$target" ]; then
          skipped+=("$skill (real dir exists)")
          continue
        fi
        if [ -L "$target" ]; then
          link_dest="$(readlink "$target" 2>/dev/null || true)"
          if [ "$link_dest" != "$REPO_ROOT/$skill" ] && [ "$link_dest" != "ai-creative-agency/$skill" ]; then
            skipped+=("$skill (symlink to $link_dest)")
            continue
          fi
        fi
        # Use a relative target so the symlink stays portable if the
        # parent dir is later moved/renamed by the user.
        ln -snf "ai-creative-agency/$skill" "$target"
        linked=$((linked + 1))
      done
      log "✓ Claude Code: linked $linked skills into $CLAUDE_SKILLS_DIR/"
      if [ ${#skipped[@]} -gt 0 ]; then
        log "  skipped (name conflicts with existing entries):"
        for s in "${skipped[@]}"; do log "    - $s"; done
      fi
      ;;
    *)
      log "✓ Claude Code: ${#SKILLS[@]} skills found at $REPO_ROOT"
      log "  note: repo is outside ~/.claude/skills/ — clone there directly to enable Desktop discovery,"
      log "        or symlink the repo: ln -s \"$REPO_ROOT\" ~/.claude/skills/ai-creative-agency, then re-run ./setup"
      ;;
  esac
fi

# ─── Codex: one symlink per skill ─────────────────────────────
# Codex scans ~/.codex/skills/ for top-level skill directories. We link
# each skill as ~/.codex/skills/<slug>/ → <repo>/<slug>/. Slash commands
# match the README catalog (e.g. /research-niche).
if [ "$INSTALL_CODEX" -eq 1 ]; then
  CODEX_SKILLS_DIR="$HOME/.codex/skills"
  mkdir -p "$CODEX_SKILLS_DIR"

  # Clean up stale aca-* symlinks from earlier prefixed installs
  if [ -d "$CODEX_SKILLS_DIR" ]; then
    for entry in "$CODEX_SKILLS_DIR"/aca-*; do
      [ -e "$entry" ] || continue
      if [ -L "$entry" ]; then
        link_dest="$(readlink "$entry" 2>/dev/null || true)"
        case "$link_dest" in
          "$REPO_ROOT"/*) rm -f "$entry" ;;
        esac
      fi
    done
  fi

  linked=0
  skipped=()
  for skill in "${SKILLS[@]}"; do
    target="$CODEX_SKILLS_DIR/$skill"
    if [ -e "$target" ] && [ ! -L "$target" ]; then
      skipped+=("$skill (real dir exists)")
      continue
    fi
    if [ -L "$target" ]; then
      link_dest="$(readlink "$target" 2>/dev/null || true)"
      if [ "$link_dest" != "$REPO_ROOT/$skill" ]; then
        skipped+=("$skill (symlink to $link_dest)")
        continue
      fi
    fi
    ln -snf "$REPO_ROOT/$skill" "$target"
    linked=$((linked + 1))
  done
  log "✓ Codex: linked $linked skills into $CODEX_SKILLS_DIR/"
  if [ ${#skipped[@]} -gt 0 ]; then
    log "  skipped (name conflicts with existing entries):"
    for s in "${skipped[@]}"; do log "    - $s"; done
  fi
fi

# ─── Summary ──────────────────────────────────────────────────
log ""
log "Sample skills:"
count=0
for skill in "${SKILLS[@]}"; do
  desc=$(awk '/^description:/{sub(/^description: */,""); print; exit}' "$skill/SKILL.md")
  printf "  /%-22s — %s\n" "$skill" "$desc"
  count=$((count + 1))
  [ "$count" -ge 8 ] && break
done
log "  ... (${#SKILLS[@]} total — see AGENTS.md for the full catalog)"
log ""
log "Set provider API keys before running. See docs/PROVIDERS.md."
